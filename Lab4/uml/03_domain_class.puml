@startuml DomainClassDiagram

skinparam class {
  BackgroundColor<<entity>> #E8F5E9
  BorderColor<<entity>> #2E7D32
}

class "用户" as User <<entity>> {
  - 用户ID : Integer
  - 用户名 : String(50)
  - 密码哈希 : String(255)
  - 姓名 : String(100)
  - 年龄 : Integer
  - 性别 : String(10)
  - 身高 : Float
  - 体重 : Float
  - 职业 : String(100)
  - 创建时间 : DateTime
  --
  + 获取个人信息() : UserOut
  + 更新个人信息(更新数据: UserUpdate) : UserOut
  + 验证密码(明文密码: String) : Boolean
  + 哈希密码(密码: String) : String
}

class "健康记录" as HealthRecord <<entity>> {
  - 记录ID : Integer
  - 用户ID : Integer [FK]
  - 记录日期 : DateTime
  - 心率 : Integer
  - 收缩压 : Integer
  - 舒张压 : Integer
  - 体重 : Float
  - 睡眠时长 : Float
  - 饮水量 : Integer
  - 步数 : Integer
  - 创建时间 : DateTime
  --
  + 创建记录(数据: HealthRecordCreate) : HealthRecord
  + 获取记录列表(数量: Integer) : List<HealthRecord>
  + 获取最新记录() : HealthRecord
  + 删除记录(记录ID: Integer) : void
  + 判断数据异常() : Boolean
}

class "AI对话" as AIConversation <<entity>> {
  - 消息ID : Integer
  - 用户ID : Integer [FK]
  - 角色 : String(20)
  - 内容 : Text
  - 创建时间 : DateTime
  --
  + 保存消息(用户ID: Integer, 角色: String, 内容: String) : AIConversation
  + 获取对话历史(数量: Integer) : List<AIConversation>
  + 构建健康上下文(用户: User, 记录: List<HealthRecord>) : String
}

class "提醒" as Reminder <<entity>> {
  - 提醒ID : Integer
  - 用户ID : Integer [FK]
  - 类型 : String(20)
  - 消息内容 : Text
  - 触发时间 : DateTime
  - 是否已读 : Boolean
  --
  + 创建提醒(用户ID: Integer, 类型: String, 消息: String) : Reminder
  + 标记已读() : void
  + 获取未读提醒() : List<Reminder>
  + 判断是否触发(健康记录: HealthRecord) : Boolean
}

User "1" *-- "0..*" HealthRecord : 拥有 >
User "1" *-- "0..*" AIConversation : 拥有 >
User "1" *-- "0..*" Reminder : 拥有 >
HealthRecord "0..1" ..> "0..*" Reminder : <<依赖>> 触发 >

@enduml
