@startuml Sequence_DataEntry

actor 用户
participant "DataEntryView\n(数据录入界面)" as DEV <<boundary>>
participant "HealthDataController\n(健康数据控制器)" as HDC <<control>>
participant "HealthRecord\n(健康记录)" as HR <<entity>>
participant "ReminderController\n(提醒控制器)" as RC <<control>>
participant "Reminder\n(提醒)" as R <<entity>>

用户 -> DEV : 填写健康数据(心率、血压、体重等)
DEV -> HDC : 提交健康数据
HDC -> HDC : 范围校验(心率30-220、血压60-250等)

alt 校验通过
    HDC -> HR : 创建健康记录
    HR --> HDC : 返回已保存记录
    HDC -> HDC : 检查数据是否异常(血压>140/90等)

    alt 数据异常
        HDC -> RC : 触发异常预警
        RC -> R : 创建异常提醒
        R --> RC : 提醒已创建
        RC --> HDC : 预警已触发
    end

    HDC --> DEV : 返回成功
    DEV --> 用户 : 显示"健康数据已同步"

else 校验失败
    HDC --> DEV : 返回校验错误
    DEV --> 用户 : 显示数据不合理提示
end

@enduml
