@startuml SequenceDataEntry

actor 用户
participant "DataEntryBoundary" as DEB
participant "HealthDataControl" as HDC
participant "HealthRecord (Entity)" as HRE
participant "ReminderControl" as RC
participant "Reminder (Entity)" as REM
database "Database" as DB

用户 -> DEB: 填写健康数据表单
DEB -> HDC: create_record(data)
HDC -> HRE: 创建 HealthRecord 对象
HRE -> DB: INSERT INTO health_records
DB --> HRE: 记录已保存
HDC -> RC: run_all_checks(user_id)

RC -> DB: 查询最新健康记录
DB --> RC: HealthRecord 数据

alt 心率异常 (>120 或 <50)
  RC -> REM: 创建 abnormal 提醒
  REM -> DB: INSERT INTO reminders
end

alt 饮水不足 (<1500ml)
  RC -> REM: 创建 water 提醒
  REM -> DB: INSERT INTO reminders
end

alt 步数过少 (<2000)
  RC -> REM: 创建 sedentary 提醒
  REM -> DB: INSERT INTO reminders
end

RC --> HDC: 返回触发提醒列表
HDC --> DEB: 返回创建的记录 + 提醒
DEB --> 用户: "健康数据已同步" + 提醒通知

@enduml
