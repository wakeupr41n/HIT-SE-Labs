@startuml SequenceLogin

actor 用户
participant "LoginBoundary" as LB
participant "AuthControl" as AC
participant "User (Entity)" as UE
database "Database" as DB

用户 -> LB: 输入用户名和密码
LB -> AC: login(username, password)
AC -> DB: SELECT * FROM users WHERE username=?
DB --> AC: User record
AC -> AC: verify_password(plain, hash)

alt 密码正确
  AC -> AC: create_access_token(user_id)
  AC --> LB: 返回 JWT token
  LB --> 用户: 登录成功，跳转仪表盘
else 密码错误
  AC --> LB: HTTPException 401
  LB --> 用户: 显示"用户名或密码错误"
end

@enduml
